---
apiVersion: v1
kind: Pod
metadata:
  name: tsf-cli
  namespace: {{ ocp4_workload_trusted_software_factory_namespace }}
  labels:
    app: tsf-cli
spec:
  serviceAccountName: tsf-deployer
  restartPolicy: Never
  containers:
  - name: tsf
    image: {{ ocp4_workload_trusted_software_factory_cli_image }}:{{ ocp4_workload_trusted_software_factory_cli_tag }}
    command:
    - /bin/sh
    - -c
    - |
      # Create kubeconfig for in-cluster access
      TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
      CA_CERT=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt

      mkdir -p /tsf/.kube
      cat > /tsf/.kube/config <<EOF
      apiVersion: v1
      kind: Config
      clusters:
      - cluster:
          certificate-authority: ${CA_CERT}
          server: https://kubernetes.default.svc
        name: local
      contexts:
      - context:
          cluster: local
          user: serviceaccount
        name: local
      current-context: local
      users:
      - name: serviceaccount
        user:
          token: ${TOKEN}
      EOF

      # Keep pod running
      echo "TSF CLI pod ready"
      tail -f /dev/null
